{
    "ts-node": {
        "transpileOnly": true
    },
    "compilerOptions": {
        "module": "Node16",
        "target": "ES2020",
        "outDir": "dist",
        "noEmit": true,
        "isolatedModules": true,
        "skipLibCheck": true,
        "lib": [
            "ES2020",
            "DOM"
        ],
        "types": [
            "mocha",
            "node",
            "@wdio/globals/types",
            "@wdio/mocha-framework",
            "wdio-vscode-service"
        ],
        "sourceMap": true,
        "rootDir": "specs",
        "strict": false
    },
    "include": ["specs/*.ts"]
}